        "import joblib\n",
        "import pandas as pd\n",
        "\n",
        "def load_model():\n",
        "    return joblib.load(\"/content/sample_data/model.pkl\")\n",
        "\n",
        "def predict_heart_disease(data):\n",
        "    model = load_model()\n",
        "    prediction = model.predict(data)\n",
        "    return prediction[0]"
      ]
